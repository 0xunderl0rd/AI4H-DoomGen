{
  "name": "doomgen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local-mvp": "bash ./scripts/run-local-mvp.sh",
    "dev:local-service": "cd local-doomgen-service && uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty",
    "prepublish:audit": "bash ./scripts/prepublish-audit.sh"
  },
  "dependencies": {
    "preact": "^10.27.2",
    "zod": "^3.25.8"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
