# Provider mode: cloud | local | hybrid
VITE_PROVIDER_MODE=local
VITE_DISABLE_CLOUD_PROVIDERS=true

# Cloud providers (required for cloud or hybrid mode)
VITE_OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
VITE_OPENAI_MODEL=gpt-4.1-mini
VITE_OPENAI_IMAGE_MODEL=gpt-image-1

VITE_ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE
VITE_ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
VITE_ELEVENLABS_VOICE_ID=YOUR_ELEVENLABS_VOICE_ID

# Local planner + asset service (required for local or hybrid mode)
VITE_LOCAL_GEN_BASE_URL=http://127.0.0.1:8000
# Used when local planner routes to Ollama (OpenAI planner is preferred when key is set)
VITE_LOCAL_PLANNER_MODEL=qwen2.5:1.5b
VITE_LOCAL_ASSET_TIMEOUT_MS=180000

# Optional Doom WASM runtime URLs
VITE_DOOM_WASM_JS_URL=/doom-wasm/websockets-doom.js
VITE_DOOM_WASM_WAD_URL=/doom/doom1.wad
VITE_USE_DOOM_WASM=false
